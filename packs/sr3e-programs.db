{"_id":"sr3e-prog-0028","name":"Dewormer","type":"program","img":"icons/svg/network.svg","system":{"name":"Dewormer","type":"Protocol","category":"","rating":0,"sizeMp":0,"multiplier":3,"degradable":false,"description":"\u003cp\u003ePurges a cyberdeck or Matrix enabled device of an Infiltrating IC Agent. Takes hours equal to rating of infiltrator. Can only purge infiltrators up to its rating.\u003c/p\u003e\u003cp\u003e\u003cstrong\u003eFunction:\u003c/strong\u003e Anti-Infiltration\u003c/p\u003e","associatedPrompt":"","effect":"Purge IC"}}
