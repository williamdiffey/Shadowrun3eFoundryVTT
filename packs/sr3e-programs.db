{"_id":"sr3e-prog-0001","name":"Passcode","type":"program","img":"icons/svg/network.svg","system":{"name":"Passcode","type":"Passcode","category":"","rating":1,"sizeMp":0,"multiplier":1,"degradable":false,"description":"\u003cp\u003eLegitimate access credentials. Allows automatic marking of specified nodes without Hacking roll or Overwatch accrual.\u003c/p\u003e\u003cp\u003e\u003cem\u003eRating indicates breadth/restrictiveness of access. Can be as narrow as a single datafile or as broad as an entire host.\u003c/em\u003e\u003c/p\u003e\u003cp\u003e\u003cstrong\u003eFunction:\u003c/strong\u003e Access\u003c/p\u003e","associatedPrompt":"","effect":""}}
